@{
    ViewData["Title"] = "Liên hệ";
}

<div class="container py-4 contact-page">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item active">Liên hệ</li>
        </ol>
    </nav>

    <div class="contact-hero reveal mb-4">
        <h1 class="contact-hero__title h3 fw-bold mb-2">Liên hệ</h1>
        <p class="text-muted mb-0">Tư vấn chọn cây, chậu và chế độ tưới — gọi điện, email hoặc để lại tin nhắn bên dưới.</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-5 order-2 order-lg-1">
            <div class="contact-info-panel h-100 reveal">
                <h2 class="h5 fw-bold mb-4 pb-2 border-bottom border-2 border-primary">Thông tin</h2>
                <div class="d-flex align-items-start mb-4">
                    <span class="contact-info-panel__icon"><i class="bi bi-geo-alt-fill"></i></span>
                    <div>
                        <h6 class="mb-1 fw-bold">Địa chỉ</h6>
                        <p class="text-muted mb-0 small">123 Nguyễn Văn Linh, Q. Hải Châu, TP. Đà Nẵng</p>
                    </div>
                </div>
                <div class="d-flex align-items-start mb-4">
                    <span class="contact-info-panel__icon"><i class="bi bi-telephone-fill"></i></span>
                    <div>
                        <h6 class="mb-1 fw-bold">Điện thoại</h6>
                        <p class="text-muted mb-0 small">0123.456.789</p>
                    </div>
                </div>
                <div class="d-flex align-items-start mb-4">
                    <span class="contact-info-panel__icon"><i class="bi bi-envelope-fill"></i></span>
                    <div>
                        <h6 class="mb-1 fw-bold">Email</h6>
                        <p class="text-muted mb-0 small">contact@tnhtree.vn</p>
                    </div>
                </div>
                <div class="d-flex align-items-start">
                    <span class="contact-info-panel__icon"><i class="bi bi-clock-fill"></i></span>
                    <div>
                        <h6 class="mb-1 fw-bold">Giờ làm việc</h6>
                        <p class="text-muted mb-0 small">Thứ 2 - Thứ 7: 8:00 - 21:00<br />Chủ nhật: 9:00 - 18:00</p>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-7 order-1 order-lg-2">
            <div class="contact-form-panel reveal">
                <h2 class="h5 fw-bold mb-4">Gửi tin nhắn</h2>
                <form>
                    <div class="mb-3">
                        <label class="form-label">Họ tên</label>
                        <input type="text" class="form-control" placeholder="Nhập họ tên" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" class="form-control" placeholder="Nhập email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nội dung</label>
                        <textarea class="form-control" rows="4" placeholder="Nội dung tin nhắn..."></textarea>
                    </div>
                    <button type="button" class="btn btn-primary px-4" onclick="alert('Cảm ơn bạn đã liên hệ! Chúng tôi sẽ phản hồi sớm nhất.')">
                        <i class="bi bi-send me-2"></i>Gửi tin nhắn
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
