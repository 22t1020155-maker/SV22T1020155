<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - " : "")TNH TREE</title>
    <link rel="icon" type="image/svg+xml" href="@Url.Content("~/images/logo-tnh-tree.svg")" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500..700;1,9..144,500..700&family=Nunito+Sans:ital,opsz,wght@0,6..12,400..700;1,6..12,400..700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="auth-shell">
    <div class="auth-shell__main">
        <a class="auth-shell__brand d-inline-flex align-items-center gap-2 justify-content-center" asp-controller="Home" asp-action="Index">
            <img src="@Url.Content("~/images/logo-tnh-tree.svg")" alt="TNH TREE" width="200" height="40" asp-append-version="true" />
        </a>
        @RenderBody()
        <p class="auth-shell__footer text-center small text-muted mt-4 mb-0">
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none">Về trang chủ</a>
        </p>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
