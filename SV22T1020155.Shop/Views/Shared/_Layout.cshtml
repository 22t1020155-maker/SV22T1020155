@{
    var cart = ApplicationContext.GetSessionData<List<CartItem>>("Cart") ?? new List<CartItem>();
    int cartCount = cart.Sum(c => c.Quantity);
    bool isAuthenticated = User.Identity?.IsAuthenticated == true;
    string customerName = User.Identity?.Name ?? "";
    string currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    string currentAction = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(ViewData["Title"] != null ? ViewData["Title"] + " - " : "")TNH TREE</title>
    <link rel="icon" type="image/svg+xml" href="@Url.Content("~/images/logo-tnh-tree.svg")" asp-append-version="true" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500..700;1,9..144,500..700&family=Nunito+Sans:ital,opsz,wght@0,6..12,400..700;1,6..12,400..700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <header class="site-header">
        <div class="header-trust header-trust--ribbon header-trust--top d-none d-sm-flex justify-content-center align-items-center flex-wrap gap-2">
            <span class="header-trust__item"><i class="bi bi-telephone"></i> 0123.456.789</span>
            <span class="header-trust__sep" aria-hidden="true"></span>
            <span class="header-trust__item"><i class="bi bi-truck"></i> Giao cây tận nơi · Tư vấn chăm sóc miễn phí</span>
        </div>
        <div class="container">
            <div class="header-toolbar header-toolbar--main header-toolbar--tnh d-flex align-items-center gap-2 gap-xl-3 py-3 flex-wrap flex-xl-nowrap">
                <button class="btn btn-menu d-lg-none flex-shrink-0 order-0" type="button" data-bs-toggle="offcanvas" data-bs-target="#shopNavOffcanvas" aria-controls="shopNavOffcanvas" aria-label="Mở menu">
                    <i class="bi bi-list"></i>
                </button>

                <nav class="header-nav-quick d-none d-xl-flex align-items-center flex-shrink-0 order-xl-1" aria-label="Điều hướng nhanh">
                    <a class="header-nav-quick__link @(currentController == "Home" && currentAction == "Index" ? "is-active" : "")" asp-controller="Home" asp-action="Index">Trang chủ</a>
                    <a class="header-nav-quick__link @(currentController == "Product" ? "is-active" : "")" asp-controller="Product" asp-action="Index">Sản phẩm</a>
                    <a class="header-nav-quick__link @(currentController == "Home" && currentAction == "Contact" ? "is-active" : "")" asp-controller="Home" asp-action="Contact">Liên hệ</a>
                    <a class="header-nav-quick__link @(currentController == "Home" && currentAction == "About" ? "is-active" : "")" asp-controller="Home" asp-action="About">Giới thiệu</a>
                </nav>

                <form class="header-search d-flex flex-grow-1 order-4 order-xl-2 min-w-0 w-100 w-xl-auto" asp-controller="Product" asp-action="Index" method="get">
                    <input type="text" name="search" class="form-control" placeholder="Tìm cây, chậu, phân bón, đất trồng..."
                           value="@Context.Request.Query["search"]" />
                    <button class="btn btn-search" type="submit" aria-label="Tìm kiếm"><i class="bi bi-search"></i></button>
                </form>

                <div class="d-flex align-items-center gap-3 order-2 order-xl-3 flex-shrink-0 header-toolbar__actions">
                    <a class="header-action" asp-controller="Cart" asp-action="Index">
                        <span style="position:relative">
                            <i class="bi bi-cart3"></i>
                            @if (cartCount > 0)
                            {
                                <span class="cart-badge">@cartCount</span>
                            }
                        </span>
                        <span class="d-none d-lg-inline">Giỏ hàng</span>
                    </a>

                    @if (isAuthenticated)
                    {
                        <div class="dropdown">
                            <a class="header-action dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i>
                                <span class="d-none d-lg-inline">@customerName</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>Tài khoản</a></li>
                                <li><a class="dropdown-item" asp-controller="Order" asp-action="History"><i class="bi bi-bag-check me-2"></i>Đơn hàng</a></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword"><i class="bi bi-key me-2"></i>Đổi mật khẩu</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Đăng xuất</a></li>
                            </ul>
                        </div>
                    }
                    else
                    {
                        <a class="header-action" asp-controller="Account" asp-action="Login">
                            <i class="bi bi-person"></i>
                            <span class="d-none d-lg-inline">Đăng nhập</span>
                        </a>
                    }
                </div>

                <a class="site-brand flex-shrink-0 order-3 ms-auto order-xl-5 header-toolbar__brand" asp-controller="Home" asp-action="Index" title="TNH TREE - Trang chủ">
                    <img class="site-brand__logo" src="@Url.Content("~/images/logo-tnh-tree.svg")" alt="TNH TREE" width="200" height="40" asp-append-version="true" />
                </a>
            </div>

            <nav class="site-nav site-nav--desktop site-nav--pill d-none d-lg-flex d-xl-none justify-content-center" aria-label="Chính">
                <ul class="nav flex-wrap justify-content-center gap-1 py-2 mb-0">
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Home" && currentAction == "Index" ? "active" : "")" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-door me-1"></i>Trang chủ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Product" ? "active" : "")" asp-controller="Product" asp-action="Index">
                            <i class="bi bi-flower2 me-1"></i>Sản phẩm
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Home" && currentAction == "Contact" ? "active" : "")" asp-controller="Home" asp-action="Contact">
                            <i class="bi bi-envelope me-1"></i>Liên hệ
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(currentController == "Home" && currentAction == "About" ? "active" : "")" asp-controller="Home" asp-action="About">
                            <i class="bi bi-info-circle me-1"></i>Giới thiệu
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </header>

    <div class="offcanvas offcanvas-start offcanvas-nav" tabindex="-1" id="shopNavOffcanvas" aria-labelledby="shopNavOffcanvasLabel">
        <div class="offcanvas-header border-bottom align-items-center">
            <div class="d-flex align-items-center gap-2 mb-0" id="shopNavOffcanvasLabel">
                <img class="site-brand__logo" style="height:36px" src="@Url.Content("~/images/logo-tnh-tree.svg")" alt="TNH TREE" asp-append-version="true" />
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Đóng"></button>
        </div>
        <div class="offcanvas-body">
            <ul class="nav flex-column gap-1">
                <li class="nav-item">
                    <a class="nav-link rounded-pill px-3 @(currentController == "Home" && currentAction == "Index" ? "active" : "")" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door me-2"></i>Trang chủ</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link rounded-pill px-3 @(currentController == "Product" ? "active" : "")" asp-controller="Product" asp-action="Index"><i class="bi bi-flower2 me-2"></i>Sản phẩm</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link rounded-pill px-3 @(currentController == "Home" && currentAction == "Contact" ? "active" : "")" asp-controller="Home" asp-action="Contact"><i class="bi bi-envelope me-2"></i>Liên hệ</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link rounded-pill px-3 @(currentController == "Home" && currentAction == "About" ? "active" : "")" asp-controller="Home" asp-action="About"><i class="bi bi-info-circle me-2"></i>Giới thiệu</a>
                </li>
            </ul>
        </div>
    </div>

    <main class="site-main py-4">
        @RenderBody()
    </main>

    <footer class="site-footer">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4">
                    <h6><span class="text-brand">TNH</span> TREE</h6>
                    <p class="small text-muted">Cây cảnh, chậu trồng và phụ kiện — tư vấn ánh sáng &amp; tưới tiêu. Giao nhanh, đóng gói cẩn thận.</p>
                    <div class="d-flex gap-3 footer-social">
                        <a href="#" aria-label="Facebook"><i class="bi bi-facebook fs-5"></i></a>
                        <a href="#" aria-label="Instagram"><i class="bi bi-instagram fs-5"></i></a>
                        <a href="#" aria-label="YouTube"><i class="bi bi-youtube fs-5"></i></a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-4">
                    <h6>Liên kết</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
                        <li class="mb-2"><a asp-controller="Product" asp-action="Index">Sản phẩm</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="About">Giới thiệu</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="Contact">Liên hệ</a></li>
                        <li class="mb-2"><a asp-controller="Home" asp-action="Privacy">Chính sách bảo mật</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4">
                    <h6>Hỗ trợ</h6>
                    <ul class="list-unstyled small">
                        <li class="mb-2"><a href="#">Chính sách đổi trả</a></li>
                        <li class="mb-2"><a href="#">Chính sách hàng chính hãng</a></li>
                        <li class="mb-2"><a href="#">Hướng dẫn mua hàng</a></li>
                        <li class="mb-2"><a href="#">Phương thức thanh toán</a></li>
                    </ul>
                </div>
                <div class="col-lg-3 col-md-4">
                    <h6>Liên hệ</h6>
                    <ul class="list-unstyled small text-muted">
                        <li class="mb-2"><i class="bi bi-geo-alt me-2"></i>123 Nguyễn Văn Linh, Đà Nẵng</li>
                        <li class="mb-2"><i class="bi bi-telephone me-2"></i>0123.456.789</li>
                        <li class="mb-2"><i class="bi bi-envelope me-2"></i>contact@tnhtree.vn</li>
                    </ul>
                </div>
            </div>
            <div class="footer-bottom">
                &copy; @DateTime.Now.Year <strong>TNH TREE</strong>. All rights reserved.
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
