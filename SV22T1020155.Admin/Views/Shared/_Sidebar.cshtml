@{
    bool IsAdmin() => User.IsInRole(AppRoles.Admin);
    bool IsManager() => User.IsInRole(AppRoles.Manager);
    bool IsSale() => User.IsInRole(AppRoles.Sale);
    bool IsAdminOrManager() => IsAdmin() || IsManager();
    bool IsAnyStaff() => IsAdminOrManager() || IsSale();
}
<aside class="app-sidebar bg-body-secondary shadow" data-bs-theme="dark">
    <div class="sidebar-brand sidebar-brand--text-only">
        <a href="~/" class="brand-link brand-link--text-only px-3 py-3 d-block text-decoration-none">
            <span class="brand-text brand-text--admin">TNH Admin</span>
        </a>
    </div>    
    <div class="sidebar-wrapper">
        <nav class="mt-2">            
            <ul class="nav sidebar-menu flex-column" data-lte-toggle="treeview" role="navigation"
                aria-label="Main navigation" data-accordion="false" id="navigation">

                <li class="nav-item">
                    <a href="~/" class="nav-link">
                        <i class="nav-icon bi bi-speedometer2"></i>
                        <p>Trang chủ</p>
                    </a>
                </li>

                <li class="nav-item menu-open">
                    <a href="#" class="nav-link active">
                        <i class="nav-icon bi bi-archive"></i>
                        <p>
                            Quản lý dữ liệu
                            <i class="nav-arrow bi bi-chevron-right"></i>
                        </p>
                    </a>
                    <ul class="nav nav-treeview">
                        @if (IsAdminOrManager())
                        {
                            <li class="nav-item">
                                <a href="~/Supplier" class="nav-link">
                                    <i class="nav-icon bi bi-truck"></i>
                                    <p>Nhà cung cấp</p>
                                </a>
                            </li>
                        }
                        @if (IsAnyStaff())
                        {
                            <li class="nav-item">
                                <a href="~/Customer" class="nav-link">
                                    <i class="nav-icon bi bi-people"></i>
                                    <p>Khách hàng</p>
                                </a>
                            </li>
                        }
                        @if (IsAdminOrManager())
                        {
                            <li class="nav-item">
                                <a href="~/Shipper" class="nav-link">
                                    <i class="nav-icon bi bi-bicycle"></i>
                                    <p>Người giao hàng</p>
                                </a>
                            </li>
                        }
                        @if (IsAdminOrManager())
                        {
                            <li class="nav-item">
                                <a href="~/Category" class="nav-link">
                                    <i class="nav-icon bi bi-bookmarks"></i>
                                    <p>Loại hàng</p>
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a href="~/Product" class="nav-link">
                                <i class="nav-icon bi bi-box-seam"></i>
                                <p>Mặt hàng</p>
                            </a>
                        </li>
                    </ul>
                </li>

                @if (IsAdminOrManager())
                {
                    <li class="nav-item">
                        <a href="~/Employee" class="nav-link">
                            <i class="nav-icon bi bi-person-badge"></i>
                            <p>Nhân viên</p>
                        </a>
                    </li>
                }

                <li class="nav-item">
                    <a href="~/Order" class="nav-link">
                        <i class="nav-icon bi bi-cart-check"></i>
                        <p>Quản lý đơn hàng</p>
                    </a>
                </li>

            </ul>
        </nav>
    </div>
</aside>
